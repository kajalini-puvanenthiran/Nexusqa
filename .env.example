# NEXUS QA Configuration

# API Security
SECRET_KEY=nexus_qa_ultra_secret_key_change_me
ACCESS_TOKEN_EXPIRE_MINUTES=480

# PostgreSQL (Primary App DB)
DATABASE_URL=postgresql://nexusqa:nexusqa123@localhost:5432/nexusqa
DATABASE_URL_ASYNC=postgresql+asyncpg://nexusqa:nexusqa123@localhost:5432/nexusqa

# MySQL (Reporting / Analysis DB)
MYSQL_URL=mysql+pymysql://nexusqa:nexusqa123@localhost:3306/nexusqa_reports

# Redis (Task Queue / Caching)
REDIS_URL=redis://localhost:6379/0

# Anthropic API
ANTHROPIC_API_KEY=

# Server Config
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Frontend Config
VITE_API_URL=http://localhost:8000

# n8n Integration
N8N_WEBHOOK_URL=http://localhost:5678/webhook/nexusqa
N8N_API_KEY=

# JIRA Automation
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=

# Deployment (Vercel/Docker)
PROJECT_NAME=NEXUSQA
ENV=development
